# Production Environment Variables for Electron Agent
NODE_ENV=production

# Set LOCAL_BUILD=true to connect to LAN dev machine (192.168.7.72) instead of production
LOCAL_BUILD=false

# Backend URLs - Production (used when LOCAL_BUILD is not true)
BACKEND_URL=https://laitlum.lipiq.in
BACKEND_WS_URL=wss://laitlum.lipiq.in/ws
WS_SERVER_URL=wss://laitlum.lipiq.in/ws

# Signaling Server Port
SIGNALING_PORT=8081

# Logging
LOG_LEVEL=info
